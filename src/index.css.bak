@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');

/* ═══════════════════════════════════════════════════════════
   NIYANTA AI — Enterprise Design System
   n8n-inspired minimal black/white console aesthetic
   ═══════════════════════════════════════════════════════════ */

:root {
  /* Surface */
  --bg-canvas: #0a0a0a;
  --bg-surface: #111111;
  --bg-surface-raised: #181818;
  --bg-surface-overlay: #1e1e1e;
  --bg-surface-sunken: #0d0d0d;
  --bg-input: #141414;

  /* Interactive */
  --bg-hover: rgba(255,255,255,0.04);
  --bg-active: rgba(255,255,255,0.07);
  --bg-selected: rgba(255,255,255,0.09);

  /* Borders */
  --border-default: #2a2a2a;
  --border-subtle: #222222;
  --border-strong: #3a3a3a;

  /* Text */
  --text-primary: #e8e8e8;
  --text-secondary: #a0a0a0;
  --text-tertiary: #666666;
  --text-inverse: #0a0a0a;

  /* Brand */
  --color-primary: #ffffff;
  --color-primary-dim: rgba(255,255,255,0.08);
  --color-accent: #3b82f6;
  --color-accent-dim: rgba(59,130,246,0.12);

  /* Status */
  --color-success: #22c55e;
  --color-success-dim: rgba(34,197,94,0.1);
  --color-warning: #eab308;
  --color-warning-dim: rgba(234,179,8,0.1);
  --color-error: #ef4444;
  --color-error-dim: rgba(239,68,68,0.1);
  --color-info: #3b82f6;
  --color-info-dim: rgba(59,130,246,0.1);

  /* Node Colors */
  --node-trigger: #6366f1;
  --node-ai: #f59e0b;
  --node-decision: #8b5cf6;
  --node-action: #22c55e;
  --node-data: #06b6d4;
  --node-monitor: #ef4444;
  --node-utility: #64748b;

  /* Spacing */
  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-5: 20px;
  --space-6: 24px;
  --space-8: 32px;
  --space-10: 40px;

  /* Radius */
  --radius-sm: 4px;
  --radius-md: 6px;
  --radius-lg: 8px;
  --radius-xl: 12px;
  --radius-full: 9999px;

  /* Shadow */
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.3);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
  --shadow-lg: 0 8px 24px rgba(0,0,0,0.5);
  --shadow-overlay: 0 16px 48px rgba(0,0,0,0.6);

  /* Sidebar */
  --sidebar-width: 64px;
  --sidebar-expanded: 240px;

  /* Typography */
  --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
  --font-size-xs: 11px;
  --font-size-sm: 12px;
  --font-size-base: 13px;
  --font-size-md: 14px;
  --font-size-lg: 16px;
  --font-size-xl: 18px;
  --font-size-2xl: 24px;
  --font-size-3xl: 32px;

  /* Transition */
  --transition-fast: 120ms ease;
  --transition-normal: 200ms ease;
  --transition-slow: 300ms ease;
}

[data-theme='light'] {
  --bg-canvas: #f5f5f5;
  --bg-surface: #ffffff;
  --bg-surface-raised: #fafafa;
  --bg-surface-overlay: #ffffff;
  --bg-surface-sunken: #f0f0f0;
  --bg-input: #f7f7f7;
  --bg-hover: rgba(0,0,0,0.03);
  --bg-active: rgba(0,0,0,0.06);
  --bg-selected: rgba(0,0,0,0.08);
  --border-default: #e2e2e2;
  --border-subtle: #eeeeee;
  --border-strong: #cccccc;
  --text-primary: #171717;
  --text-secondary: #525252;
  --text-tertiary: #a3a3a3;
  --text-inverse: #ffffff;
  --color-primary: #171717;
  --color-primary-dim: rgba(0,0,0,0.05);
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.06);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
  --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
  --shadow-overlay: 0 16px 48px rgba(0,0,0,0.15);
}

/* ─── Reset ─────────────────────────────────────────── */

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background: var(--bg-canvas);
  color: var(--text-primary);
  font-family: var(--font-sans);
  font-size: var(--font-size-base);
  line-height: 1.5;
  height: 100vh;
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

#root {
  height: 100vh;
  overflow: hidden;
}

/* ─── Scrollbar ─────────────────────────────────────── */

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: var(--radius-full); }
::-webkit-scrollbar-thumb:hover { background: var(--text-tertiary); }

/* ─── Selection ─────────────────────────────────────── */

::selection {
  background: var(--color-accent);
  color: white;
}

/* ─── Focus ─────────────────────────────────────────── */

:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}

/* ─── Base Elements ─────────────────────────────────── */

a {
  color: var(--text-secondary);
  text-decoration: none;
}
a:hover {
  color: var(--text-primary);
}

button {
  cursor: pointer;
  font-family: inherit;
  font-size: inherit;
}
button:disabled {
  cursor: not-allowed;
  opacity: 0.4;
}

input, textarea, select {
  font-family: inherit;
  font-size: inherit;
  color: var(--text-primary);
  outline: none;
}

/* ─── Animations ────────────────────────────────────── */

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

@keyframes blink {
  0%, 80%, 100% { opacity: 0.2; }
  40% { opacity: 1; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

/* ─── Utility Classes ───────────────────────────────── */

.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mono {
  font-family: var(--font-mono);
}

.status-dot {
  width: 6px;
  height: 6px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.status-dot--active { background: var(--color-success); }
.status-dot--warning { background: var(--color-warning); }
.status-dot--error { background: var(--color-error); }
.status-dot--idle { background: var(--text-tertiary); }

/* ─── Niyanta Layout ────────────────────────────────── */

.nyt-app {
  display: flex;
  height: 100vh;
  overflow: hidden;
}

/* ─── Sidebar (Icon Rail) ────────────────────────────── */

.nyt-sidebar {
  width: var(--sidebar-width);
  height: 100vh;
  background: var(--bg-surface);
  border-right: 1px solid var(--border-default);
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  z-index: 10;
}

.nyt-sidebar__logo {
  width: var(--sidebar-width);
  height: 56px;
  display: grid;
  place-items: center;
  border-bottom: 1px solid var(--border-default);
}

.nyt-sidebar__logo-mark {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-md);
  background: var(--text-primary);
  color: var(--text-inverse);
  display: grid;
  place-items: center;
  font-weight: 700;
  font-size: var(--font-size-sm);
  letter-spacing: 0.04em;
  font-family: var(--font-mono);
}

.nyt-sidebar__nav {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2) 0;
  gap: var(--space-1);
}

.nyt-sidebar__item {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  border: none;
  background: transparent;
  color: var(--text-tertiary);
  display: grid;
  place-items: center;
  transition: all var(--transition-fast);
  position: relative;
  font-size: 18px;
}

.nyt-sidebar__item:hover {
  background: var(--bg-hover);
  color: var(--text-secondary);
}

.nyt-sidebar__item--active {
  background: var(--bg-active);
  color: var(--text-primary);
}

.nyt-sidebar__item--active::before {
  content: '';
  position: absolute;
  left: -12px;
  width: 3px;
  height: 20px;
  background: var(--text-primary);
  border-radius: 0 2px 2px 0;
}

.nyt-sidebar__item-label {
  position: absolute;
  left: calc(100% + 12px);
  background: var(--bg-surface-overlay);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-sm);
  padding: 4px 8px;
  font-size: var(--font-size-xs);
  white-space: nowrap;
  pointer-events: none;
  opacity: 0;
  transition: opacity var(--transition-fast);
  z-index: 100;
}

.nyt-sidebar__item:hover .nyt-sidebar__item-label {
  opacity: 1;
}

.nyt-sidebar__divider {
  width: 24px;
  height: 1px;
  background: var(--border-default);
  margin: var(--space-2) 0;
}

.nyt-sidebar__footer {
  padding: var(--space-3) 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  border-top: 1px solid var(--border-default);
}

/* ─── Content Area ───────────────────────────────────── */

.nyt-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.nyt-topbar {
  height: 48px;
  border-bottom: 1px solid var(--border-default);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-5);
  background: var(--bg-surface);
  flex-shrink: 0;
}

.nyt-topbar__title {
  font-size: var(--font-size-md);
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.nyt-topbar__breadcrumb {
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
}

.nyt-topbar__actions {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.nyt-main {
  flex: 1;
  overflow: hidden;
  position: relative;
}

/* ─── Buttons ────────────────────────────────────────── */

.nyt-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: 6px 12px;
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  font-weight: 500;
  border: 1px solid var(--border-default);
  background: var(--bg-surface);
  color: var(--text-primary);
  transition: all var(--transition-fast);
  white-space: nowrap;
}

.nyt-btn:hover:not(:disabled) {
  background: var(--bg-hover);
  border-color: var(--border-strong);
}

.nyt-btn--primary {
  background: var(--text-primary);
  color: var(--text-inverse);
  border-color: var(--text-primary);
}

.nyt-btn--primary:hover:not(:disabled) {
  opacity: 0.9;
  background: var(--text-primary);
}

.nyt-btn--ghost {
  border: none;
  background: transparent;
  color: var(--text-secondary);
}

.nyt-btn--ghost:hover:not(:disabled) {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.nyt-btn--danger {
  color: var(--color-error);
  border-color: var(--color-error);
  background: var(--color-error-dim);
}

.nyt-btn--danger:hover:not(:disabled) {
  background: var(--color-error);
  color: white;
}

.nyt-btn--sm {
  padding: 4px 8px;
  font-size: var(--font-size-xs);
}

.nyt-btn--lg {
  padding: 10px 20px;
  font-size: var(--font-size-md);
}

.nyt-btn--icon {
  width: 32px;
  height: 32px;
  padding: 0;
  display: grid;
  place-items: center;
}

/* ─── Input ──────────────────────────────────────────── */

.nyt-input {
  width: 100%;
  padding: 8px 12px;
  border: 1px solid var(--border-default);
  border-radius: var(--radius-md);
  background: var(--bg-input);
  color: var(--text-primary);
  font-size: var(--font-size-sm);
  transition: border-color var(--transition-fast);
}

.nyt-input:focus {
  border-color: var(--border-strong);
}

.nyt-input::placeholder {
  color: var(--text-tertiary);
}

.nyt-textarea {
  width: 100%;
  padding: 8px 12px;
  border: 1px solid var(--border-default);
  border-radius: var(--radius-md);
  background: var(--bg-input);
  color: var(--text-primary);
  font-size: var(--font-size-sm);
  resize: vertical;
  min-height: 80px;
  transition: border-color var(--transition-fast);
}

.nyt-textarea:focus {
  border-color: var(--border-strong);
}

.nyt-select {
  width: 100%;
  padding: 8px 12px;
  border: 1px solid var(--border-default);
  border-radius: var(--radius-md);
  background: var(--bg-input);
  color: var(--text-primary);
  font-size: var(--font-size-sm);
  appearance: none;
}

/* ─── Badge ──────────────────────────────────────────── */

.nyt-badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: 500;
  background: var(--color-primary-dim);
  color: var(--text-secondary);
  border: 1px solid var(--border-default);
}

.nyt-badge--success {
  background: var(--color-success-dim);
  color: var(--color-success);
  border-color: transparent;
}

.nyt-badge--warning {
  background: var(--color-warning-dim);
  color: var(--color-warning);
  border-color: transparent;
}

.nyt-badge--error {
  background: var(--color-error-dim);
  color: var(--color-error);
  border-color: transparent;
}

.nyt-badge--info {
  background: var(--color-info-dim);
  color: var(--color-info);
  border-color: transparent;
}

/* ─── Card ───────────────────────────────────────────── */

.nyt-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
}

.nyt-card--hoverable {
  transition: all var(--transition-fast);
  cursor: pointer;
}

.nyt-card--hoverable:hover {
  border-color: var(--border-strong);
  background: var(--bg-surface-raised);
}

/* ─── Table ──────────────────────────────────────────── */

.nyt-table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--font-size-sm);
}

.nyt-table th {
  text-align: left;
  padding: var(--space-2) var(--space-3);
  font-weight: 500;
  color: var(--text-tertiary);
  font-size: var(--font-size-xs);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-bottom: 1px solid var(--border-default);
}

.nyt-table td {
  padding: var(--space-3);
  border-bottom: 1px solid var(--border-subtle);
  color: var(--text-secondary);
}

.nyt-table tr:hover td {
  background: var(--bg-hover);
}

/* ─── Modal ──────────────────────────────────────────── */

.nyt-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(4px);
  display: grid;
  place-items: center;
  z-index: 1000;
  animation: fadeIn 0.15s ease;
}

.nyt-modal {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-overlay);
  animation: scaleIn 0.2s ease;
  display: flex;
  flex-direction: column;
}

.nyt-modal__header {
  height: 52px;
  border-bottom: 1px solid var(--border-default);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-4);
}

.nyt-modal__title {
  font-weight: 600;
  font-size: var(--font-size-md);
}

.nyt-modal__body {
  flex: 1;
  overflow-y: auto;
  padding: var(--space-4);
}

.nyt-modal__footer {
  border-top: 1px solid var(--border-default);
  padding: var(--space-3) var(--space-4);
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--space-2);
}

/* ─── Empty State ────────────────────────────────────── */

.nyt-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-10);
  text-align: center;
  color: var(--text-tertiary);
}

.nyt-empty__icon {
  font-size: 48px;
  margin-bottom: var(--space-4);
  opacity: 0.3;
}

.nyt-empty__text {
  font-size: var(--font-size-md);
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
}

.nyt-empty__sub {
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
}

/* ─── Spinner ────────────────────────────────────────── */

.nyt-spinner {
  width: 16px;
  height: 16px;
  border: 2px solid var(--border-default);
  border-top-color: var(--text-primary);
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

.nyt-spinner--sm { width: 12px; height: 12px; }
.nyt-spinner--lg { width: 24px; height: 24px; }

/* ─── Responsive ─────────────────────────────────────── */

@media (max-width: 768px) {
  .nyt-sidebar { display: none; }
}
