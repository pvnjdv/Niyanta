{
  "name": "niyanta-ai",
  "version": "2.0.0",
  "description": "Niyanta AI — Autonomous Enterprise Workflow Orchestration Platform",
  "private": true,
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon --config nodemon.json server/index.ts",
    "client": "react-scripts start",
    "build": "npm run build:server && react-scripts build",
    "build:server": "tsc -p tsconfig.server.json",
    "start:prod": "node dist/server/index.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "groq-sdk": "^0.30.0",
    "better-sqlite3": "^11.7.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "pdfkit": "^0.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/cors": "^2.8.18",
    "@types/morgan": "^1.9.10",
    "@types/better-sqlite3": "^7.6.12",
    "@types/uuid": "^10.0.0",
    "@types/pdfkit": "^0.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.8.2",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.9",
    "concurrently": "^8.2.2"
  },
  "proxy": "http://localhost:3001",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version"
    ]
  }
}
