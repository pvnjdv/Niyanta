{
  "name": "niyanta-ai",
  "version": "1.0.0",
  "description": "Niyanta AI — Autonomous Enterprise Governor",
  "main": "dist/server.js",
  "proxy": "http://localhost:3001",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "react-scripts build",
    "server": "ts-node server.ts",
    "server:prod": "node dist/server.js",
    "client": "react-scripts start",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "ai",
    "enterprise",
    "autonomous",
    "agents",
    "claude",
    "anthropic",
    "typescript"
  ],
  "author": "",
  "license": "MIT"
}
